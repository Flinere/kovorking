<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="kovorking.CreateBookingWindow"
        Title="CreateBookingWindow" xmlns:local="clr-namespace:kovorking"
        xmlns:models="clr-namespace:kovorking.Models">
        <StackPanel Margin="20" Spacing="15">
        <TextBlock Text="Клиент:" FontWeight="Bold" Foreground="#ffa07a"/>
        <ComboBox Name="ComboUsers" Background="#F5F5DC">
                <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:User">
                                <TextBlock Text="{Binding FullName}"/>
                        </DataTemplate>
                </ComboBox.ItemTemplate>
        </ComboBox>
        
        <TextBlock Text="Помещение:" FontWeight="Bold" Foreground="#ffa07a"/>
        <ComboBox Name="ComboRooms" Background="#F5F5DC">
                <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:Room">
                                <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                </ComboBox.ItemTemplate>
        </ComboBox>
        
        <StackPanel Orientation="Horizontal" Spacing="10">
                <StackPanel>
                        <TextBlock Text="Дата:" Foreground="#ffa07a"/>
                        <DatePicker Name="PickDate" Background="#F5F5DC" Width="140"/>
                </StackPanel>
                <StackPanel>
                        <TextBlock Text="Время:" Foreground="#ffa07a"/>
                        <TimePicker Name="PickTime" Background="#F5F5DC" Width="300" ClockIdentifier="24HourClock"/>
                </StackPanel>
                <StackPanel>
                        <TextBlock Text="Часов:" Foreground="#ffa07a"/>
                        <TextBox Name="TxtHours" Text="1" Width="60" Background="#F5F5DC"/>
                </StackPanel>
        </StackPanel>

        <Button Content="Проверить доступность" Background="#ffa07a" Click="BtnCheckAvailability_Click"/>
        
        <TextBlock Name="LblStatus" Foreground="Gray" Text="Статус: Новое"/>
        
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
                <Button Content="Сохранить" Background="#ffa07a" Width="100" Click="BtnSave_Click"/>
                <Button Content="Отмена" Background="#ffa07a" Width="100" Click="BtnCancel_Click"/>
        </StackPanel>
        </StackPanel>
</Window>
